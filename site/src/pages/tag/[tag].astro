---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
  const tags = new Set<string>();

  try {
    const indexesDir = new URL('../../public/data/indexes/', import.meta.url);
    const files = await fs.readdir(indexesDir);
    for (const file of files) {
      if (!file.endsWith('.json')) continue;
      const content = await fs.promises.readFile(new URL(`./${file}`, indexesDir), 'utf-8');
      const data = JSON.parse(content);
      if (data.tags && Array.isArray(data.tags)) {
        for (const t of data.tags) tags.add(t);
      }
    }
  } catch {
    // No indexes data yet
  }

  return [...tags].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

let items: any[] = [];
let dates: string[] = [];

// Search through available item files
// In a real implementation, this would use a search index
---

<Layout title={`#${tag}`}>
  <h1>标签: {tag}</h1>

  {items.length > 0 ? (
    <ul class="item-list">
      {items.map((item) => (
        <li>
          <a href={item.canonical_url} target="_blank" rel="noopener">
            {item.title}
          </a>
          <span class="source">{item.domain}</span>
          <span class="date">{item.published_at?.split('T')[0]}</span>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">未找到带有该标签的消息</p>
  )}
</Layout>

<style>
  .item-list {
    list-style: none;
    padding: 0;
  }

  .item-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .item-list a {
    color: var(--color-link);
    text-decoration: none;
  }

  .source, .date {
    display: block;
    font-size: 0.85rem;
    color: #888;
  }

  .date {
    margin-top: 0.25rem;
  }

  .empty {
    color: #666;
    text-align: center;
    padding: 3rem 0;
  }
</style>
