---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';

export async function getStaticPaths() {
  const digestFiles = new Set<string>();

  try {
    const digestsDir = new URL('../../public/data/digests/', import.meta.url);
    const files = await fs.readdir(digestsDir);
    for (const file of files) {
      const match = file.match(/^(\d{4}-\d{2}-\d{2})\.json$/);
      if (match) digestFiles.add(match[1]);
    }
  } catch {
    // No digests data yet
  }

  return [...digestFiles].map(date => ({ params: { date } }));
}

const { date } = Astro.params;

let digest = null;
let topics = [];

try {
  const digestResponse = await fetch(`/data/digests/${date}.json`);
  if (digestResponse.ok) {
    digest = await digestResponse.json();

    // Load topics
    const topicResponse = await fetch(`/data/topics/${date}.json`);
    if (topicResponse.ok) {
      const allTopics = await topicResponse.json();
      // Handle both array format and {clusters: [...]} format
      const clusters = Array.isArray(allTopics) ? allTopics : (allTopics.clusters || []);
      for (const topicId of digest.top_topic_ids || []) {
        const topic = clusters.find((t: any) => t.topic_id === topicId);
        if (topic) topics.push(topic);
      }
    }
  }
} catch (e) {
  // Data not available
}
---

<Layout title={date || '日期'}>
  <p><a href="/archive">← 返回归档</a></p>

  {digest ? (
    <article>
      <header>
        <h1>{digest.headline}</h1>
        <p class="lead">{digest.lead}</p>
        <p class="date">{digest.date}</p>
      </header>

      <section class="stats">
        <span>原始消息: {digest.stats.raw_items}</span>
        <span>标准化消息: {digest.stats.normalized_items}</span>
        <span>发布消息: {digest.stats.published_items}</span>
        <span>专题数: {digest.stats.topics}</span>
      </section>

      <section class="topics">
        <h2>专题</h2>
        {topics.map((topic: any) => (
          <div class="topic">
            <h3>
              <a href={`/topic/${topic.topic_id}`}>{topic.name}</a>
            </h3>
            <p>{topic.summary}</p>
            {topic.why_it_matters && (
              <p class="why"><strong>为什么重要:</strong> {topic.why_it_matters}</p>
            )}
          </div>
        ))}
      </section>
    </article>
  ) : (
    <p class="not-found">未找到 {date} 的数据</p>
  )}
</Layout>

<style>
  .lead {
    font-size: 1.2rem;
    color: #444;
    line-height: 1.8;
  }

  .date {
    color: #888;
  }

  .stats {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 2rem 0;
    flex-wrap: wrap;
  }

  .stats span {
    color: #666;
  }

  .topics {
    margin-top: 3rem;
  }

  .topic {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .topic h3 {
    margin-bottom: 0.5rem;
  }

  .topic h3 a {
    color: var(--color-link);
    text-decoration: none;
  }

  .why {
    background: #f9f9f9;
    padding: 1rem;
    border-radius: 4px;
    margin-top: 1rem;
  }

  .not-found {
    text-align: center;
    padding: 3rem 0;
    color: #666;
  }
</style>
