---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI Daily Brief - 每日 AI 资讯晚报' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | AI Daily Brief</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">首页</a>
        <a href="/archive">归档</a>
        <a href="/about">关于</a>
        <a href="/status">状态</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 AI Daily Brief</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --color-bg: #ffffff;
    --color-text: #333333;
    --color-link: #0066cc;
    --color-border: #e0e0e0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    line-height: 1.6;
    color: var(--color-text);
    background: var(--color-bg);
    margin: 0;
    padding: 0;
  }

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    gap: 2rem;
  }

  nav a {
    color: var(--color-link);
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    text-align: center;
    color: #666;
  }
</style>
